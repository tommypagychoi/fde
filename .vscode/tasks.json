{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: compose up",
      "type": "shell",
      "command": "docker compose up --build",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "panel": "dedicated", "reveal": "always" }
    },
    {
      "label": "Backend: run local",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8000 --reload",
      "options": { "cwd": "${workspaceFolder}\\backend" },
      "problemMatcher": []
    },
    {
      "label": "Backend: syntax check",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -B -c \"import ast, pathlib; [ast.parse(p.read_text(encoding='utf-8'), filename=str(p)) for p in pathlib.Path('app').glob('*.py')]; from app.main import app; print('Backend check OK:', app.title)\"",
      "options": { "cwd": "${workspaceFolder}\\backend" },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
